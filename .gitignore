# ---- Node (root-level) ----
node_modules/

# ---- Frontend ----
frontend/node_modules/
# frontend/dist/ is intentionally TRACKED for deployment (server has no Node.js).
# The root 'dist/' rule above would match it, so we explicitly un-ignore it:
!frontend/dist/
!frontend/dist/**
frontend/build/
frontend/.vite/
frontend/.next/
frontend/coverage/
frontend/.env
frontend/.env.*
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# ---- Tray app ----
tray/dist/
tray/build/
tray/.cache/
tray/node_modules/
tray/.env
tray/.env.*

