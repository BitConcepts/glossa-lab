    { "id": "extract",  "type": "expNode", "data": { "atomicId": "RefinedMeluhhanPersonsExtractorV2", "label": "Refined persons v2",                "params": { "min_freq": 1 } },                                         "position": { "x": 360,  "y": 100 } },
    { "id": "matcher",  "type": "expNode", "data": { "atomicId": "EnhancedNameMatcherV2",             "label": "Bipartite matcher v2",              "params": { "min_name_freq": 1, "tolerance": 2 } },                     "position": { "x": 660,  "y": 60 } },
    { "id": "readout",  "type": "expNode", "data": { "atomicId": "BilingualReadoutTestV2",            "label": "Bipartite readout test v2 (2k perms)","params": { "n_permutations": 2000, "min_name_freq": 1, "tolerance": 2, "seed": 42 } }, "position": { "x": 660, "y": 200 } },
    { "id": "merge",    "type": "expNode", "data": { "atomicId": "Merger",                            "label": "Merge",                              "params": {} },                                                       "position": { "x": 960,  "y": 130 } },
    { "id": "out",      "type": "expNode", "data": { "atomicId": "JSONExport",                        "label": "Save Phase-24d results",             "params": { "filename": "phase24d_readout_test_v2.json" } },           "position": { "x": 1260, "y": 130 } }
  ],
  "edges": [
