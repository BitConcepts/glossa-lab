    {"id": "sa_skt",    "type": "expNode", "data": {"atomicId": "SADecipher",         "label": "SA vs Sanskrit (GPU)",                 "params": {"n_seeds": 5, "max_iterations": 8000, "restarts": 3, "surjective": true, "ocp_weight": 0.0}},               "position": {"x": 840,  "y": 620}},
