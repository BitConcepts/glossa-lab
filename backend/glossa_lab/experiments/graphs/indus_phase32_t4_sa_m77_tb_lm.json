{
  "id": "indus_phase32_t4_sa_m77_tb_lm",
  "name": "Indus Phase-32 T4 — SA Decipherment M77 → Dravidian Tamil LM (P30-H1)",
  "description": "Phase-32 T4: THE CRITICAL NON-CIRCULAR TEST. Runs SimulatedAnnealing on the full M77 Holdat corpus (1,670 inscriptions, 7,002 tokens) using the clean Dravidian Tamil bigram LM (dravidian_tamil_lm.json — built from DEDR+Sangam+Parpola, 486 bigrams, CLEAN, 0/15 English contamination) as the scoring target, with HIGH/MEDIUM INDUS_FINAL_ANCHORS as fixed starting points (333 entries). This test is non-circular: the LM is built from independent Tamil lexical/literary sources (DEDR, Sangam corpus), NOT from the Indus corpus itself. If SA finds a mapping significantly above a random null baseline, it is the strongest positive evidence for the Dravidian hypothesis produced so far. Null result = strong structural evidence against. Cites: A.1 (Mahadevan 1977), E.1 (DEDR/Burrow+Emeneau), E.3 (Sangam), C.2 (Parpola 2010).",
  "auto_migrated": false,
  "nodes": [
    {
      "id": "m77",
      "type": "expNode",
      "data": {
        "atomicId": "M77InscriptionLoader",
        "label": "Load M77 Holdat corpus",
        "params": { "use_raw": false, "label": "indus_m77" }
      },
      "position": { "x": 60, "y": 120 }
    },
    {
      "id": "lm",
      "type": "expNode",
      "data": {
        "atomicId": "BuiltinLM",
        "label": "Dravidian Tamil LM (DEDR+Sangam+Parpola — CLEAN)",
        "params": { "language": "dravidian" }
      },
      "position": { "x": 60, "y": 320 }
    },
    {
      "id": "anchors",
      "type": "expNode",
      "data": {
        "atomicId": "DerivedAnchorSet",
        "label": "INDUS_FINAL_ANCHORS (HIGH+MEDIUM, 333 entries)",
        "params": { "min_confidence": "MEDIUM" }
      },
      "position": { "x": 60, "y": 520 }
    },
    {
      "id": "sa",
      "type": "expNode",
      "data": {
        "atomicId": "SADecipher",
        "label": "SA M77 → Tamil LM (5 seeds × 10000 iters)",
