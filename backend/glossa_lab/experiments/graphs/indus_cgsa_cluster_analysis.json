{
  "id": "indus_cgsa_cluster_analysis",
  "name": "Indus CGSA Cluster Sequence Analysis",
  "description": "CGSA Phase 5-6: Load CISI corpus, map signs to structural clusters (40 classes), analyze recurrent templates. NO phonetic mapping.",
  "nodes": [
    {
      "id": "n1",
      "type": "expNode",
      "data": {
        "atomicId": "BuiltinCorpus",
        "label": "CISI Corpus",
        "params": {"corpus": "indus_cisi"}
      }
    },
    {
      "id": "n2",
      "type": "expNode",
      "data": {
        "atomicId": "CanonicalSignLoader",
        "label": "Canonical Sign Registry",
        "params": {"in_corpus_only": true, "numbering_system": ""}
      }
    },
    {
      "id": "n3",
      "type": "expNode",
      "data": {
        "atomicId": "ClusterMapper",
        "label": "Cluster Mapper (40 classes)",
        "params": {}
      }
    },
    {
      "id": "n4",
      "type": "expNode",
      "data": {
        "atomicId": "StructuralTemplateAnalyzer",
        "label": "Structural Template Analyzer",
        "params": {"min_count": 3, "max_template_length": 5}
      }
    },
    {
      "id": "n5",
      "type": "expNode",
      "data": {
        "atomicId": "PositionalProfiler",
        "label": "Positional Profiler",
        "params": {"min_count": 3}
      }
    },
    {
      "id": "n6",
      "type": "expNode",
      "data": {
        "atomicId": "Merger",
        "label": "Merge Results",
        "params": {}
      }
    },
    {
      "id": "n7",
      "type": "expNode",
      "data": {
        "atomicId": "JSONExport",
        "label": "Export",
        "params": {"filename": "indus_cgsa_cluster_analysis.json"}
      }
    }
  ],
  "edges": [
    {"id": "e1", "source": "n1", "sourcePort": "sequences", "target": "n3", "targetPort": "sequences"},
    {"id": "e2", "source": "n1", "sourcePort": "sequences", "target": "n5", "targetPort": "sequences"},
    {"id": "e3", "source": "n3", "sourcePort": "cluster_sequences", "target": "n4", "targetPort": "cluster_sequences"},
    {"id": "e4", "source": "n2", "sourcePort": "registry", "target": "n6", "targetPort": "a"},
    {"id": "e5", "source": "n3", "sourcePort": "cluster_sequences", "target": "n6", "targetPort": "b"},
    {"id": "e6", "source": "n4", "sourcePort": "recurrent_templates", "target": "n6", "targetPort": "c"},
    {"id": "e7", "source": "n5", "sourcePort": "class_summary", "target": "n6", "targetPort": "d"},
    {"id": "e8", "source": "n6", "sourcePort": "json", "target": "n7", "targetPort": "data"}
  ]
}
