# ---- Tray app ----
tray/dist/
tray/build/
tray/.cache/
tray/node_modules/
tray/.env
tray/.env.*

# ---- Generic logs ----
*.log
logs/
tmp/
temp/

# ---- Service/runtime artifacts ----
*.pid
*.pid.lock
*.sock
