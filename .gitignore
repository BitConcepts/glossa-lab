*.msi
*.exe
*.dmg
*.AppImage
*.deb
*.rpm

# ---- Archives ----
*.zip
*.tar
*.tar.gz
*.tgz
*.7z

# ---- Systemd / service-generated local files ----
services/linux/*.service.local
services/windows/*.local.json

# ---- Keep placeholders ----
!backend/.gitkeep
!frontend/.gitkeep
!tray/.gitkeep
!services/windows/.gitkeep
!services/linux/.gitkeep
!scripts/.gitkeep
