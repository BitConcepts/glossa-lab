    {"source": "n4", "sourceHandle": "recurrent_templates", "target": "n7", "targetHandle": "a"},
    {"source": "n4", "sourceHandle": "slot_occupancy", "target": "n7", "targetHandle": "b"},
    {"source": "n5", "sourceHandle": "class_summary", "target": "n7", "targetHandle": "c"},
    {"source": "n6", "sourceHandle": "top_10", "target": "n7", "targetHandle": "d"},
    {"source": "n2", "sourceHandle": "n_tokens", "target": "n7", "targetHandle": "e"},
