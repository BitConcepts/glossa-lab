  // Set up signup banner show/hide behavior:
  // 1. If the signup banner trigger (a 242px-high* invisible div underneath the 'See Full PDF' / 'Download PDF' buttons)
  //    is already fully scrolled above the viewport, show the banner by default
  // 2. If the signup banner trigger is fully visible, show the banner
  // 3. If the signup banner trigger has even a few pixels scrolled below the viewport, hide the banner
  //
  // * 242px is the empirically determined height of the signup banner. It's better to be a bit taller than
  //   necessary than too short, so it's fine that the mobile (small breakpoint) banner is shorter.

  // First check session storage for the signup banner's visibility state
  const signupBannerHidden = sessionStorage.getItem('ds-signup-banner-hidden');
  if (signupBannerHidden === 'true') {
    return;
  }

  const signupBanner = document.querySelector('.ds-signup-banner');
  const signupBannerTrigger = document.querySelector('.ds-signup-banner-trigger');

  let footerShown = false;

  window.addEventListener('load', () => {
    const rect = signupBannerTrigger.getBoundingClientRect();
    // If page loaded up already scrolled below the trigger (via scroll restoration), show the banner by default
    if (rect.bottom < 0) {
      footerShown = true;
      signupBanner.classList.add('ds-signup-banner-visible');
    }
  });

  // Wait for trigger to fully enter viewport before showing banner (ensures PDF CTAs are never covered by banner)
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !footerShown) {
        footerShown = true;
        signupBanner.classList.add('ds-signup-banner-visible');
      } else if (!entry.isIntersecting && footerShown) {
        if (signupBannerTrigger.getBoundingClientRect().bottom > 0) {
          footerShown = false;
          signupBanner.classList.remove('ds-signup-banner-visible');
        }
      }
    });
  });
  observer.observe(signupBannerTrigger);

  // Set up signup banner close button event handler:
  const signupBannerCloseButton = document.querySelector('#ds-signup-banner-close-button');
  signupBannerCloseButton.addEventListener('click', () => {
    signupBanner.classList.remove('ds-signup-banner-visible');
    observer.unobserve(signupBannerTrigger);

    // Store the signup banner's visibility state in session storage
    sessionStorage.setItem('ds-signup-banner-hidden', 'true');
  });
})();</script></div></div><style>@media screen and (min-width: 568px) and (max-width: 621px) {  .ds-work-card--button-container .primary-buttons .ds2-5-button, .ds-work-card--citation-button {    font-size: var(--font-size-small);    line-height: var(--line-height-small);    padding: 0 var(--buttons-small-buttons-l-r-padding, 12px);    height: var(--buttons-small-buttons-height, 44px);    gap: var(--buttons-small-buttons-gap, 8px);    border-radius: var(--buttons-small-buttons-corner-radius, 8px);  }}@media screen and (min-width: 1280px) and (max-width: 1515px) {  .ds-work-card--button-container .primary-buttons .ds2-5-button, .ds-work-card--citation-button {    font-size: var(--font-size-small);    line-height: var(--line-height-small);    padding: 0 var(--buttons-small-buttons-l-r-padding, 12px);    height: var(--buttons-small-buttons-height, 44px);    gap: var(--buttons-small-buttons-gap, 8px);    border-radius: var(--buttons-small-buttons-corner-radius, 8px);  } .ds-work-card--button-container {   flex-direction: column !important; } .ds-work-card--button-container .share-and-save-buttons {   align-self: start; }}@media screen and (min-width: 1280px) {  .ds-work-card--work-authors.ds-work-card--work-authors--mobile-only {    display: none !important;  }}</style><div data-auto_select="false" data-client_id="331998490334-rsn3chp12mbkiqhl6e7lu2q0mlbu0f1b" data-doc_id="49802974" data-landing_url="https://www.academia.edu/4530410/_With_Gerald_Holton_and_Edward_Jurkowitz_How_a_Scientific_Discovery_is_Made_A_Case_History_American_Scientist_84_1996_364_375" data-login_uri="https://www.academia.edu/registrations/google_one_tap" data-use_fedcm_for_prompt="true" id="g_id_onload"></div><div class="safe-figure-carousel-section--container"><div class="safe-figure-carousel-section--heading" id="figures">Figures (12)</div><div class="safe-figure-carousel--container"><div class="carousel-container js-figure-carousel carousel-container--md" id="loswp-figures"><div class="prev-slide-container js-prev-button-container"><button aria-label="Previous" class="carousel-navigation-button js-loswp-figures-prev"><span class="material-symbols-outlined" style="font-size: 24px" translate="no">arrow_back_ios</span></button></div><div class="slides-container js-slides-container"><figure class="figure-slide-container"><a href="https://www.academia.edu/figures/48604768/figure-1-ductivity-had-the-affective-power-of-mandala-the"><img alt="ductivity had the affective power of a mandala, the highly symmetrical visual symbol of the universe used in Hinduism and Buddhism as a guide to meditation. Miiller later chose the Dharmaraja mandala, above, to illustrate an introspective essay on his sources of inspiration. " class="figure-slide-image" loading="eager" src="https://figures.academia-assets.com/49802974/figure_001.jpg" width="236" height="141" /></a><figcaption class="figure-slide-caption ds2-5-body-xs">ductivity had the affective power of a mandala, the highly symmetrical visual symbol of the universe used in Hinduism and Buddhism as a guide to meditation. Miiller later chose the Dharmaraja mandala, above, to illustrate an introspective essay on his sources of inspiration. </figcaption></figure><figure class="figure-slide-container"><a href="https://www.academia.edu/figures/48604786/figure-2-superconductivity-the-loss-of-electrical-resistance"><img alt="Figure 2. Superconductivity, the loss of electrical resistance in a material, was discovered by the Dutch physicist Heike Kamerlingh Onnes (right, shown with colleague G. J. Flim and their helium-liquefying apparatus in 1922). Onnes found that mercury becomes supercon- ducting at 4.2 degrees Kelvin (above absolute zero). Until Karl Alex Miller and Georg Bednorz published papers in 1986 describing a material that becomes superconducting at 30 Kelvin, the discovery of superconductivity appeared to have little practical use. Onnes is only one of a large number of scientific “ancestors” to Miiller and Bednorz. (Photograph courtesy of the Deutsches Museum, Munich.) " class="figure-slide-image" loading="eager" src="https://figures.academia-assets.com/49802974/figure_002.jpg" width="236" height="141" /></a><figcaption class="figure-slide-caption ds2-5-body-xs">Figure 2. Superconductivity, the loss of electrical resistance in a material, was discovered by the Dutch physicist Heike Kamerlingh Onnes (right, shown with colleague G. J. Flim and their helium-liquefying apparatus in 1922). Onnes found that mercury becomes supercon- ducting at 4.2 degrees Kelvin (above absolute zero). Until Karl Alex Miller and Georg Bednorz published papers in 1986 describing a material that becomes superconducting at 30 Kelvin, the discovery of superconductivity appeared to have little practical use. Onnes is only one of a large number of scientific “ancestors” to Miiller and Bednorz. (Photograph courtesy of the Deutsches Museum, Munich.) </figcaption></figure><figure class="figure-slide-container"><a href="https://www.academia.edu/figures/48604803/figure-3-but-the-seeds-of-fascination-with-the-field-had"><img alt="But the seeds of fascination with the field had been sown, and when Miller asked Bednorz in 1983 to join him in the search for a new superconductor, Bednorz accepted with such alacrity " class="figure-slide-image" loading="eager" src="https://figures.academia-assets.com/49802974/figure_003.jpg" width="236" height="141" /></a><figcaption class="figure-slide-caption ds2-5-body-xs">But the seeds of fascination with the field had been sown, and when Miller asked Bednorz in 1983 to join him in the search for a new superconductor, Bednorz accepted with such alacrity </figcaption></figure><figure class="figure-slide-container"><a href="https://www.academia.edu/figures/48604812/figure-4-discovery-of-the-first-high-temperature"><img alt="Figure 4. Discovery of the first high-temperature superconductor, barium-doped lan- thanum cuprate, was published in Zeitschrift fiir Physik B, a journal read by few supercon- ductivity researchers. Although there was good evidence that the compound was supercon- ducting, confirming measurements of magnetic susceptibility and the determination of the Meissner effect had yet to be made. The crucial figure showed the temperature depen- dence of the resistivity of lanthanum cuprates doped with varying amounts of barium (Ba,Lag_,Cu,O5y_,)- (The two upper curves should be read against the left scale and the lower one against the right scale.) After initially increasing as the temperature was low- ered, resistivity suddenly plunged to zero. The figure’s shock value, however, lay in its abscissa: The materials underwent this transition at temperatures well above absolute  zero. (Reprinted with permission of Springer-Verlag.) " class="figure-slide-image" loading="eager" src="https://figures.academia-assets.com/49802974/figure_004.jpg" width="236" height="141" /></a><figcaption class="figure-slide-caption ds2-5-body-xs">Figure 4. Discovery of the first high-temperature superconductor, barium-doped lan- thanum cuprate, was published in Zeitschrift fiir Physik B, a journal read by few supercon- ductivity researchers. Although there was good evidence that the compound was supercon- ducting, confirming measurements of magnetic susceptibility and the determination of the Meissner effect had yet to be made. The crucial figure showed the temperature depen- dence of the resistivity of lanthanum cuprates doped with varying amounts of barium (Ba,Lag_,Cu,O5y_,)- (The two upper curves should be read against the left scale and the lower one against the right scale.) After initially increasing as the temperature was low- ered, resistivity suddenly plunged to zero. The figure’s shock value, however, lay in its abscissa: The materials underwent this transition at temperatures well above absolute  zero. (Reprinted with permission of Springer-Verlag.) </figcaption></figure><figure class="figure-slide-container"><a href="https://www.academia.edu/figures/48604819/figure-5-miiller-decided-to-investigate-the-lanthanum"><img alt="Figure 5. Miiller decided to investigate the lanthanum cuprates in part because he thought they were perovskites, a class of ceramics characterized by a highly symmetrical crystal structure. A crystal can be described as a lattice, or space-filling construct, adhering to certain operations that define the relations among points in the lattice. These operations include, for example, rotations about a point and reflections about a plane. Each of seven crystal systems—the cubic, tetragonal, orthorhombic, hexagonal, trigonal, monoclinic and triclinic—is defined by a set of symmetry elements. By analogy, the manner in which a crystal system exhibits a set of symme- try elements can be grasped by examining M. C. Escher’s “Study for Regular Division of the Plane with Angels and Devils,” a two-dimensional space-filling construct. The pattern, which has twofold and fourfold rotational symmetry (a) and mirror symmetry (b,c), can be construct- ed by repetition of a square motif (d). " class="figure-slide-image" loading="eager" src="https://figures.academia-assets.com/49802974/figure_005.jpg" width="236" height="141" /></a><figcaption class="figure-slide-caption ds2-5-body-xs">Figure 5. Miiller decided to investigate the lanthanum cuprates in part because he thought they were perovskites, a class of ceramics characterized by a highly symmetrical crystal structure. A crystal can be described as a lattice, or space-filling construct, adhering to certain operations that define the relations among points in the lattice. These operations include, for example, rotations about a point and reflections about a plane. Each of seven crystal systems—the cubic, tetragonal, orthorhombic, hexagonal, trigonal, monoclinic and triclinic—is defined by a set of symmetry elements. By analogy, the manner in which a crystal system exhibits a set of symme- try elements can be grasped by examining M. C. Escher’s “Study for Regular Division of the Plane with Angels and Devils,” a two-dimensional space-filling construct. The pattern, which has twofold and fourfold rotational symmetry (a) and mirror symmetry (b,c), can be construct- ed by repetition of a square motif (d). </figcaption></figure><figure class="figure-slide-container"><a href="https://www.academia.edu/figures/48604827/figure-6-symmetries-of-the-perovskites-upper-left-and"><img alt="Figure 6. Symmetries of the perovskites (upper left) and lanthanum superconductors (right) are often explained with polyhedral models. In an ABO, perovskite six oxygen atoms (blue splieres) surround the B cations, which form an octahedron. A cations are shown in yellow, forming a network linked by green “bonds.” Lanthanum cuprate (La,CuO,) has a similar structure, but the copper-bearing octahedra shaxe four rather than six corners, and thus form Cu-O planes tha‘  enhance the potential for superconductivity. " class="figure-slide-image" loading="eager" src="https://figures.academia-assets.com/49802974/figure_006.jpg" width="236" height="141" /></a><figcaption class="figure-slide-caption ds2-5-body-xs">Figure 6. Symmetries of the perovskites (upper left) and lanthanum superconductors (right) are often explained with polyhedral models. In an ABO, perovskite six oxygen atoms (blue splieres) surround the B cations, which form an octahedron. A cations are shown in yellow, forming a network linked by green “bonds.” Lanthanum cuprate (La,CuO,) has a similar structure, but the copper-bearing octahedra shaxe four rather than six corners, and thus form Cu-O planes tha‘  enhance the potential for superconductivity. </figcaption></figure><figure class="figure-slide-container"><a href="https://www.academia.edu/figures/48604836/figure-7-with-gerald-holton-and-edward-jurkowitz-how"><img alt="" class="figure-slide-image" loading="eager" src="https://figures.academia-assets.com/49802974/figure_007.jpg" width="236" height="141" /></a><figcaption class="figure-slide-caption ds2-5-body-xs"></figcaption></figure><figure class="figure-slide-container"><a href="https://www.academia.edu/figures/48604848/figure-8-oe-fo-determine-the-immediate-intellectual-and"><img alt="_ oe ¢ fo determine the immediate intellectual and material “ancestry” of the discovery of high-temperature superconductors, the autho! traced implicit and explicit citations (“+” indicates additional coauthors) in five papers that can be regarded as the essential core of th  ture superconductivity: schema, the theoretical framework in which the scientists phrased their inquiry; production, the experimental tech niques and material resources needed to produce the superconducting compound; observation, the means of gathering and analyzing dat about the compound&#39;s properties; and interpretation, the theoretical concepts needed to interpret the data they obtained. Although intellectu  al Ptimacy is often given to theory, the proper apparatus can play at least as important a role in scientific advances; all work with supercon ductors, for example, was predicated on the development of the means to reach temperatures near absolute zero. " class="figure-slide-image" loading="eager" src="https://figures.academia-assets.com/49802974/figure_008.jpg" width="236" height="141" /></a><figcaption class="figure-slide-caption ds2-5-body-xs">_ oe ¢ fo determine the immediate intellectual and material “ancestry” of the discovery of high-temperature superconductors, the autho! traced implicit and explicit citations (“+” indicates additional coauthors) in five papers that can be regarded as the essential core of th  ture superconductivity: schema, the theoretical framework in which the scientists phrased their inquiry; production, the experimental tech niques and material resources needed to produce the superconducting compound; observation, the means of gathering and analyzing dat about the compound&#39;s properties; and interpretation, the theoretical concepts needed to interpret the data they obtained. Although intellectu  al Ptimacy is often given to theory, the proper apparatus can play at least as important a role in scientific advances; all work with supercon ductors, for example, was predicated on the development of the means to reach temperatures near absolute zero. </figcaption></figure><figure class="figure-slide-container"><a href="https://www.academia.edu/figures/48604863/figure-8-borrowing-of-resources-routinely-takes-place"><img alt="Borrowing of resources routinely takes place between different traditions within a conventionally defined discipline. For in- stance, among the theoretical ancestors of the Bednorz-Miiller work are ideas from thermodynamics, statistical me- chanics, the old quantum theory, quantum mechanics and quantum field theory. Even when a given work superficially appears to be the result of a narrow line of research, it is likely to have a deep and broad ancestry. When scientists borrow from different sub- fields, these can blend together or be transformed in an alchemical process that turns them into gold. One may also note that the unpredictable way scien-  Figure 8. More complete genealogical analysis of the Bednorz-Miiller achieve- ment quickly uncovered a broad and deep network of intellectual and material ances- tors, grouped here generally as in Figure 7, with schema resources at the top and inter- pretive work at the bottom. For illustrative " class="figure-slide-image" loading="eager" src="https://figures.academia-assets.com/49802974/figure_009.jpg" width="236" height="141" /></a><figcaption class="figure-slide-caption ds2-5-body-xs">Borrowing of resources routinely takes place between different traditions within a conventionally defined discipline. For in- stance, among the theoretical ancestors of the Bednorz-Miiller work are ideas from thermodynamics, statistical me- chanics, the old quantum theory, quantum mechanics and quantum field theory. Even when a given work superficially appears to be the result of a narrow line of research, it is likely to have a deep and broad ancestry. When scientists borrow from different sub- fields, these can blend together or be transformed in an alchemical process that turns them into gold. One may also note that the unpredictable way scien-  Figure 8. More complete genealogical analysis of the Bednorz-Miiller achieve- ment quickly uncovered a broad and deep network of intellectual and material ances- tors, grouped here generally as in Figure 7, with schema resources at the top and inter- pretive work at the bottom. For illustrative </figcaption></figure><figure class="figure-slide-container"><a href="https://www.academia.edu/figures/48604876/figure-10-our-findings-emphasize-the-great-impor-tance-for"><img alt="Our findings emphasize the great impor- tance for scientific research of unintended  Purposes, the first-generation ancestors (red lines) are shown in more detail than earlier generations (green lines). The genealogical tree has been arbitrarily truncated; each generation, of course, has its own ancestors. Even without the ability to indicate every traceable “ances- tor,” the figure embodies the central argument of this article, namely that every scientific advance depends on many previous advances in a variety of unrelated disciplines. Likewise resources interconnect: Observation leads to new theory and vice versa. Schemes for directing funds solely to “strategic” research areas ignore the dense interconnectedness of the scientific enterprise. Note that the horizontal scale is compressed as one passes into the 19th century (facing page). Also, some important work in this field is absent in this representative ‘sketch of the authors’ genealogical tracing because of lack of space, or because Miiller and Bednorz did not refer to it.  basic research borrows resources from applied research, and applied research bor- rows resources from basic research. A good example of this symmetrical exchange is Bednorz and Miiller’s use of a SQUID (superconducting quantum interference device) to measure changes in magnetic fields. The initial pursuit of superconductivity can be regarded as asic, Or “curiosity-driven.” So can Bri- an. Josephson’s prediction that super- conducting currents can tunnel across in insulating film. But then the Joseph- on effect led to the production of " class="figure-slide-image" loading="eager" src="https://figures.academia-assets.com/49802974/figure_010.jpg" width="236" height="141" /></a><figcaption class="figure-slide-caption ds2-5-body-xs">Our findings emphasize the great impor- tance for scientific research of unintended  Purposes, the first-generation ancestors (red lines) are shown in more detail than earlier generations (green lines). The genealogical tree has been arbitrarily truncated; each generation, of course, has its own ancestors. Even without the ability to indicate every traceable “ances- tor,” the figure embodies the central argument of this article, namely that every scientific advance depends on many previous advances in a variety of unrelated disciplines. Likewise resources interconnect: Observation leads to new theory and vice versa. Schemes for directing funds solely to “strategic” research areas ignore the dense interconnectedness of the scientific enterprise. Note that the horizontal scale is compressed as one passes into the 19th century (facing page). Also, some important work in this field is absent in this representative ‘sketch of the authors’ genealogical tracing because of lack of space, or because Miiller and Bednorz did not refer to it.  basic research borrows resources from applied research, and applied research bor- rows resources from basic research. A good example of this symmetrical exchange is Bednorz and Miiller’s use of a SQUID (superconducting quantum interference device) to measure changes in magnetic fields. The initial pursuit of superconductivity can be regarded as asic, Or “curiosity-driven.” So can Bri- an. Josephson’s prediction that super- conducting currents can tunnel across in insulating film. But then the Joseph- on effect led to the production of </figcaption></figure><figure class="figure-slide-container"><a href="https://www.academia.edu/figures/48604889/figure-9-density-of-connections-that-characterizes"><img alt="Figure 9. Density of connections that characterizes genealogical analysis of scientific WOrK iS demonstrated by focusing on one node in Figure 8—the BCS theory for low-temperature superconductivity—which explodes to reveal its own dense network of ancestors. This fig; ure also illustrates a quixotic aspect of scientific discovery: The BCS theory in its original form is now widely thought not to apply to high-temperature superconductors, but ideas do  not have to be correct to be fruitful. " class="figure-slide-image" loading="eager" src="https://figures.academia-assets.com/49802974/figure_011.jpg" width="236" height="141" /></a><figcaption class="figure-slide-caption ds2-5-body-xs">Figure 9. Density of connections that characterizes genealogical analysis of scientific WOrK iS demonstrated by focusing on one node in Figure 8—the BCS theory for low-temperature superconductivity—which explodes to reveal its own dense network of ancestors. This fig; ure also illustrates a quixotic aspect of scientific discovery: The BCS theory in its original form is now widely thought not to apply to high-temperature superconductors, but ideas do  not have to be correct to be fruitful. </figcaption></figure><figure class="figure-slide-container"><a href="https://www.academia.edu/figures/48604906/figure-12-with-gerald-holton-and-edward-jurkowitz-how"><img alt="" class="figure-slide-image" loading="eager" src="https://figures.academia-assets.com/49802974/figure_012.jpg" width="236" height="141" /></a><figcaption class="figure-slide-caption ds2-5-body-xs"></figcaption></figure></div><div class="next-slide-container js-next-button-container"><button aria-label="Next" class="carousel-navigati