        "x": 60,
        "y": 100
      }
    },
    {
      "id": "out",
      "type": "expNode",
      "data": {
        "atomicId": "JSONExport",
        "label": "Save run summary",
        "params": {
          "filename": "phase19_omnibus.json"
        }
      },
      "position": {
        "x": 360,
        "y": 100
      }
    }
  ],
  "edges": [
    {
      "id": "e_run_out",
      "source": "run",
      "target": "out",
