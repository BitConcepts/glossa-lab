    { "id": "cas_indo_aryan",     "type": "expNode", "data": { "atomicId": "CASHypothesisProjector", "label": "CPSC: M77 vs Indo-Aryan",     "params": { "builtin": "indo_aryan_morphology" } },     "position": { "x": 1780, "y": 140 } },
    { "id": "cas_sumerian",       "type": "expNode", "data": { "atomicId": "CASHypothesisProjector", "label": "CPSC: M77 vs Sumerian",       "params": { "builtin": "sumerian_morphology" } },       "position": { "x": 1780, "y": 220 } },
    { "id": "cas_elamo_dravidian","type": "expNode", "data": { "atomicId": "CASHypothesisProjector", "label": "CPSC: M77 vs Elamo-Dravidian","params": { "builtin": "elamo_dravidian_morphology" } },"position": { "x": 1780, "y": 300 } },

    { "id": "rank", "type": "expNode", "data": { "atomicId": "MultiHypothesisRanker", "label": "Multi-hypothesis ranker (P15 step 3)", "params": { "labels": ["dravidian", "indo_aryan", "sumerian", "elamo_dravidian"] } }, "position": { "x": 2080, "y": 180 } },

    { "id": "merge", "type": "expNode", "data": { "atomicId": "Merger", "label": "Merge Phase-15 results", "params": {} }, "position": { "x": 2380, "y": 280 } },
    { "id": "out",   "type": "expNode", "data": { "atomicId": "JSONExport", "label": "Save Phase-15 results", "params": { "filename": "indus_phase15_full.json" } }, "position": { "x": 2640, "y": 280 } }
  ],
