{
  "id": "geez_anchor_convergence",
  "name": "Geez Syllabic Anchor-Convergence Benchmark",
  "description": "Controlled cipher benchmark on the Geez Genesis corpus (Dr. Fuls). Builds a syllabic LM from the training split, creates a random bijective cipher on the test split, then sweeps anchor counts [0,3,10,20] measuring free-sign accuracy, consistency, and cluster collapse. Answers definitively: do anchors drive convergence in a true syllabic system?",
  "nodes": [
    {
      "id": "corpus",
      "type": "expNode",
      "data": {
        "atomicId": "BuiltinCorpus",
        "label": "Geez Genesis",
        "params": {
          "corpus": "geez"
        }
      },
      "position": {
        "x": 60,
        "y": 240
      }
    },
    {
      "id": "split",
      "type": "expNode",
      "data": {
        "atomicId": "CorpusSplitter",
        "label": "75/25 Split",
        "params": {
          "train_ratio": 0.75
        }
      },
      "position": {
        "x": 300,
        "y": 240
      }
    },
    {
      "id": "lm",
      "type": "expNode",
      "data": {
        "atomicId": "LMBuilder",
        "label": "Syllabic LM (train)",
        "params": {}
      },
      "position": {
        "x": 560,
        "y": 100
      }
    },
    {
      "id": "cipher",
      "type": "expNode",
      "data": {
        "atomicId": "CipherConstructor",
        "label": "Random Cipher",
        "params": {
          "cipher_seed": 42,
          "max_tokens": 15000
        }
      },
      "position": {
        "x": 560,
        "y": 380
      }
    },
    {
      "id": "benchmark",
      "type": "expNode",
      "data": {
        "atomicId": "AnchorConvergenceBenchmark",
        "label": "Anchor Convergence Sweep",
        "params": {
          "anchor_counts": [
            0,
            3,
            10,
            20
          ],
          "n_structured": 3,
          "n_random": 5,
          "n_seeds_base": 5,
          "n_seeds_struct": 3,
          "n_seeds_rand": 2,
          "sa_iterations": 2000,
          "sa_restarts": 1
        }
      },
      "position": {
        "x": 820,
        "y": 240
      }
    },
    {
      "id": "out",
