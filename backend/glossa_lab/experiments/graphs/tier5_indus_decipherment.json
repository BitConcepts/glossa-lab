{
  "id": "tier5_indus_decipherment",
  "name": "Tier 5 — Indus Script Decipherment Hypothesis Test",
  "description": "Tests Dravidian vs Sanskrit vs Sumerian as target language hypotheses for the Indus Script (Tier 5 logo-syllabic system). Filters hapax signs (min_freq=8) to isolate phonogram candidates per the Fuls anti-circularity protocol. BeamDecipher is applied against each reference LM. Structural entropy and writing-system classification are also computed. Results are merged and exported.",
  "nodes": [
    {"id": "corpus",    "type": "expNode", "data": {"atomicId": "BuiltinCorpus", "label": "Indus Script", "params": {"corpus": "indus"}}, "position": {"x": 60,  "y": 240}},
    {"id": "filter",    "type": "expNode", "data": {"atomicId": "TokenFilter", "label": "Filter hapax (min_freq=8)", "params": {"min_freq": 8}}, "position": {"x": 280, "y": 240}},
    {"id": "freq",      "type": "expNode", "data": {"atomicId": "FreqCounter", "label": "Freq Counter", "params": {}}, "position": {"x": 500, "y": 100}},
    {"id": "entropy",   "type": "expNode", "data": {"atomicId": "EntropyCalc", "label": "Entropy (H1)", "params": {}}, "position": {"x": 720, "y": 100}},
    {"id": "wsc",       "type": "expNode", "data": {"atomicId": "WritingSystemClassifier", "label": "Writing System Classifier", "params": {}}, "position": {"x": 960, "y": 100}},
    {"id": "profiles",  "type": "expNode", "data": {"atomicId": "PositionalProfiler", "label": "Positional Profiler", "params": {"min_count": 8}}, "position": {"x": 500, "y": 240}},
    {"id": "drav_lm",   "type": "expNode", "data": {"atomicId": "BuiltinLM", "label": "Dravidian LM", "params": {"language": "dravidian"}}, "position": {"x": 60,  "y": 480}},
    {"id": "sum_lm",    "type": "expNode", "data": {"atomicId": "BuiltinLM", "label": "Sumerian LM", "params": {"language": "sumerian"}}, "position": {"x": 60,  "y": 640}},
    {"id": "beam_drav", "type": "expNode", "data": {"atomicId": "BeamDecipher", "label": "Beam vs Dravidian", "params": {"beam_width": 200, "surjective": true}}, "position": {"x": 780, "y": 400}},
    {"id": "beam_sum",  "type": "expNode", "data": {"atomicId": "BeamDecipher", "label": "Beam vs Sumerian", "params": {"beam_width": 200, "surjective": true}}, "position": {"x": 780, "y": 600}},
    {"id": "merge",     "type": "expNode", "data": {"atomicId": "Merger", "label": "Merge All Results", "params": {}}, "position": {"x": 1200, "y": 380}},
    {"id": "out",       "type": "expNode", "data": {"atomicId": "JSONExport", "label": "Save", "params": {"filename": "tier5_indus_decipherment.json"}}, "position": {"x": 1460, "y": 380}}
  ],
  "edges": [
    {"id": "e1",  "source": "corpus",    "target": "filter",    "sourcePort": "sequences",         "targetPort": "sequences"},
    {"id": "e2",  "source": "filter",    "target": "freq",      "sourcePort": "sequences",         "targetPort": "sequences"},
    {"id": "e3",  "source": "filter",    "target": "profiles",  "sourcePort": "sequences",         "targetPort": "sequences"},
    {"id": "e4",  "source": "filter",    "target": "beam_drav", "sourcePort": "sequences",         "targetPort": "sequences"},
    {"id": "e5",  "source": "filter",    "target": "beam_sum",  "sourcePort": "sequences",         "targetPort": "sequences"},
    {"id": "e6",  "source": "freq",      "target": "entropy",   "sourcePort": "freq_map",          "targetPort": "freq_map"},
    {"id": "e7",  "source": "entropy",   "target": "wsc",       "sourcePort": "h1",                "targetPort": "h1"},
    {"id": "e8",  "source": "freq",      "target": "wsc",       "sourcePort": "distinct_symbols",  "targetPort": "distinct_symbols"},
    {"id": "e9",  "source": "drav_lm",   "target": "beam_drav", "sourcePort": "lm",                "targetPort": "lm"},
    {"id": "e10", "source": "sum_lm",    "target": "beam_sum",  "sourcePort": "lm",                "targetPort": "lm"},
    {"id": "e11", "source": "wsc",       "target": "merge",     "sourcePort": "tier_classification","targetPort": "a"},
    {"id": "e12", "source": "beam_drav", "target": "merge",     "sourcePort": "proposed_mapping",  "targetPort": "b"},
    {"id": "e13", "source": "beam_sum",  "target": "merge",     "sourcePort": "proposed_mapping",  "targetPort": "c"},
    {"id": "e14", "source": "merge",     "target": "out",       "sourcePort": "json",              "targetPort": "data"}
  ]
}
