{
  "id": "indus_south_dravidian_vs_sanskrit",
  "name": "Indus: South Dravidian (Tamil+Kannada+Telugu) vs Sanskrit — Extended A/B",
  "description": "P1a extended A/B test. Uses the combined South Dravidian LM (Tamil + Kannada + Telugu, ~90K chars) vs Sanskrit (728K-char Rigveda). Greater statistical power than the Tamil-only Dravidian test. Both arms use the Fuls anti-circularity protocol: TokenFilter(min_freq=8) removes hapax signs. GPU fast path: ocp_weight=0.0, n_seeds=5 parallel. Adjudicates Dravidian vs Indo-Aryan language family hypothesis for the Indus Script.",
  "nodes": [
    {"id": "corpus",       "type": "expNode", "data": {"atomicId": "BuiltinCorpus",     "label": "Indus Script",                  "params": {"corpus": "indus"}},                                                                                                    "position": {"x": 60,   "y": 280}},
    {"id": "filter",       "type": "expNode", "data": {"atomicId": "TokenFilter",       "label": "Filter hapax (min_freq=8)",      "params": {"min_freq": 8}},                                                                                                        "position": {"x": 280,  "y": 280}},
    {"id": "freq",         "type": "expNode", "data": {"atomicId": "FreqCounter",       "label": "Freq Counter",                  "params": {}},                                                                                                                     "position": {"x": 500,  "y": 100}},
    {"id": "entropy",      "type": "expNode", "data": {"atomicId": "EntropyCalc",       "label": "Entropy H1",                   "params": {}},                                                                                                                     "position": {"x": 720,  "y": 100}},
    {"id": "sdrav_lm",     "type": "expNode", "data": {"atomicId": "BuiltinLM",         "label": "South Dravidian LM (Tam+Kan+Tel)", "params": {"language": "south_dravidian"}},                                                                                  "position": {"x": 60,   "y": 500}},
    {"id": "skt_lm",       "type": "expNode", "data": {"atomicId": "BuiltinLM",         "label": "Sanskrit LM (Rigveda 728K)",    "params": {"language": "sanskrit"}},                                                                                             "position": {"x": 60,   "y": 680}},
    {"id": "sa_sdrav",     "type": "expNode", "data": {"atomicId": "SADecipher",        "label": "SA vs South Dravidian (GPU)",   "params": {"n_seeds": 5, "max_iterations": 6000, "restarts": 3, "surjective": true, "ocp_weight": 0.0}},                         "position": {"x": 800,  "y": 460}},
    {"id": "sa_skt",       "type": "expNode", "data": {"atomicId": "SADecipher",        "label": "SA vs Sanskrit (GPU)",          "params": {"n_seeds": 5, "max_iterations": 6000, "restarts": 3, "surjective": true, "ocp_weight": 0.0}},                         "position": {"x": 800,  "y": 680}},
    {"id": "cons_sdrav",   "type": "expNode", "data": {"atomicId": "ConsistencyScorer", "label": "Consistency (South Dravidian)", "params": {}},                                                                                                                   "position": {"x": 1080, "y": 460}},
    {"id": "cons_skt",     "type": "expNode", "data": {"atomicId": "ConsistencyScorer", "label": "Consistency (Sanskrit)",       "params": {}},                                                                                                                   "position": {"x": 1080, "y": 680}},
    {"id": "merge",        "type": "expNode", "data": {"atomicId": "Merger",            "label": "Merge A/B Results",            "params": {}},                                                                                                                   "position": {"x": 1340, "y": 380}},
    {"id": "out",          "type": "expNode", "data": {"atomicId": "JSONExport",        "label": "Save Results",                 "params": {"filename": "indus_south_dravidian_vs_sanskrit.json"}},                                                                "position": {"x": 1620, "y": 380}}
  ],
  "edges": [
    {"id": "e1",  "source": "corpus",     "target": "filter",     "sourcePort": "sequences",        "targetPort": "sequences"},
    {"id": "e2",  "source": "filter",     "target": "freq",       "sourcePort": "sequences",        "targetPort": "sequences"},
    {"id": "e3",  "source": "filter",     "target": "sa_sdrav",   "sourcePort": "sequences",        "targetPort": "sequences"},
