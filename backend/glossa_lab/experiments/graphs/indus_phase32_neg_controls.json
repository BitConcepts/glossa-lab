    { "id": "e_kl_gl_q",       "source": "freq_gl",   "target": "kl_gl",      "sourcePort": "freq_map",     "targetPort": "q" },
    { "id": "e_zr_merge",      "source": "zipf_real", "target": "merge",      "sourcePort": "zipf_exponent","targetPort": "zipf_real" },
    { "id": "e_zww_merge",     "source": "zipf_ww",   "target": "merge",      "sourcePort": "zipf_exponent","targetPort": "zipf_within_word_shuffle" },
    { "id": "e_zgl_merge",     "source": "zipf_gl",   "target": "merge",      "sourcePort": "zipf_exponent","targetPort": "zipf_global_shuffle" },
    { "id": "e_klww_merge",    "source": "kl_ww",     "target": "merge",      "sourcePort": "kl_divergence","targetPort": "kl_real_vs_ww_shuffle" },
    { "id": "e_klgl_merge",    "source": "kl_gl",     "target": "merge",      "sourcePort": "kl_divergence","targetPort": "kl_real_vs_global_shuffle" },
    { "id": "e_m77_merge_n",   "source": "m77",       "target": "merge",      "sourcePort": "n_inscriptions","targetPort": "n_inscriptions" },
    { "id": "e_merge_out",     "source": "merge",     "target": "out",        "sourcePort": "json",         "targetPort": "data" }
  ]
