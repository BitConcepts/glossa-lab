{
  "id": "indus_phase9_function_validation",
  "name": "Phase 9: Sign Function Validation (Cluster↔ICIT)",
  "description": "Cross-validates CGSA structural cluster classes (TERMINAL/INITIAL/MEDIAL) against ICIT sign function codes (ITM, TMK, LOG, NUM, SYL). A TERMINAL cluster should contain ITM/TMK-coded signs; INITIAL should contain LOG/ITM; MEDIAL should contain SYL/NUM. If our structural classes match ICIT's empirical function taxonomy, this is evidence the clusters reflect real sign roles. No phonetic mapping is performed.",
  "nodes": [
    {
      "id": "n1",
      "type": "expNode",
      "data": {
        "atomicId": "BuiltinCorpus",
        "label": "CISI Inscription Corpus",
        "params": {
          "corpus": "indus_cisi"
        }
      }
    },
    {
      "id": "n2",
      "type": "expNode",
      "data": {
        "atomicId": "PositionalProfiler",
        "label": "Positional Profiler (NWSP)",
        "params": {
          "min_count": 3
        }
      }
    },
    {
      "id": "n3",
      "type": "expNode",
      "data": {
        "atomicId": "ClusterMapper",
        "label": "Map Signs→Structural Clusters",
        "params": {}
      }
    },
    {
      "id": "n4",
      "type": "expNode",
      "data": {
        "atomicId": "CanonicalSignLoader",
        "label": "Canonical Registry (ICIT functions)",
        "params": {
          "in_corpus_only": true,
          "numbering_system": "parpola_1982"
        }
      }
    },
    {
      "id": "n5",
      "type": "expNode",
      "data": {
        "atomicId": "CASIndusEngine",
        "label": "CAS Indus Role Classifier",
        "params": {
          "terminal_threshold": 0.55,
          "initial_threshold": 0.45,
          "engine": "iterative"
        }
      }
    },
    {
      "id": "n6",
      "type": "expNode",
      "data": {
        "atomicId": "Merger",
        "label": "Merge Validation Evidence",
        "params": {}
      }
    },
    {
      "id": "n7",
      "type": "expNode",
      "data": {
        "atomicId": "JSONExport",
        "label": "Export Function Validation",
        "params": {
          "filename": "phase9_function_validation.json"
        }
      }
    }
  ],
