{
  "id": "indus_anchor_sweep",
  "name": "Tier 5 — Indus Script Anchor Convergence Sweep (Dravidian)",
  "description": "Anchor amplification sweep for the Indus Script Tier 5 phonogram set vs Dravidian LM. Applies the Fuls anti-circularity protocol (TokenFilter min_freq=8) to isolate phonogram candidates. Runs AnchorConvergenceBenchmark across k = 0, 3, 10, 20 anchors using structured (frequency-ranked) and random anchor sets. Tests whether injecting structural anchors — high T-rate signs identified as logograms/determinatives — drives SA consistency from ~98% toward 100% and reduces cluster diversity. Key experiment for the Indus Dravidian hypothesis.",
  "nodes": [
    {"id": "corpus",    "type": "expNode", "data": {"atomicId": "CorpusReader",  "label": "Indus (ICIT multi-sign)",  "params": {"corpus_id": ""}},                                                                    "position": {"x": 60,   "y": 260}},
    {"id": "filter",    "type": "expNode", "data": {"atomicId": "TokenFilter",     "label": "Filter hapax (min_freq=8)", "params": {"min_freq": 8}},                                                                  "position": {"x": 280,  "y": 260}},
    {"id": "lm",        "type": "expNode", "data": {"atomicId": "BuiltinLM",       "label": "Dravidian (Tamil) LM",     "params": {"language": "dravidian"}},                                                        "position": {"x": 60,   "y": 460}},
    {"id": "cipher",    "type": "expNode", "data": {"atomicId": "CipherConstructor","label": "Build Cipher (seed=42)",  "params": {"cipher_seed": 42, "max_tokens": 3000}},                                          "position": {"x": 500,  "y": 260}},
    {"id": "bench",     "type": "expNode", "data": {"atomicId": "AnchorConvergenceBenchmark", "label": "Anchor Sweep k=0,3,10,20", "params": {"anchor_counts": [0, 3, 10, 20], "n_structured": 3, "n_random": 3, "n_seeds_base": 5, "n_seeds_struct": 3, "n_seeds_rand": 2, "sa_iterations": 3000, "sa_restarts": 2, "use_word_final_anchors": true}}, "position": {"x": 760,  "y": 360}},
    {"id": "out",       "type": "expNode", "data": {"atomicId": "JSONExport",       "label": "Save",                     "params": {"filename": "indus_anchor_sweep.json"}},                                          "position": {"x": 1060, "y": 360}}
  ],
  "edges": [
    {"id": "e1", "source": "corpus",  "target": "filter",  "sourcePort": "sequences",        "targetPort": "sequences"},
    {"id": "e2", "source": "filter",  "target": "cipher",  "sourcePort": "sequences",        "targetPort": "sequences"},
    {"id": "e3", "source": "lm",      "target": "cipher",  "sourcePort": "lm",               "targetPort": "lm"},
    {"id": "e4", "source": "cipher",  "target": "bench",   "sourcePort": "cipher_sequences", "targetPort": "cipher_sequences"},
    {"id": "e5", "source": "lm",      "target": "bench",   "sourcePort": "lm",               "targetPort": "lm"},
    {"id": "e6", "source": "cipher",  "target": "bench",   "sourcePort": "true_mapping",     "targetPort": "true_mapping"},
    {"id": "e7", "source": "cipher",  "target": "bench",   "sourcePort": "sign_inventory",   "targetPort": "sign_inventory"},
    {"id": "e8", "source": "bench",   "target": "out",     "sourcePort": "summary_table",    "targetPort": "data"}
  ]
}
