{
  "id": "indus_phase15_full",
  "name": "Indus Phase-15 \u2014 long-tail validity, cipher self-test, hypothesis ranker",
  "description": "Phase-15 has three concurrent steps. Step 1: re-run Phase-14's MI-decay + HED tests on the long-tail subset of M77 (inscriptions >= 7 signs, 283 of 1669) to discriminate the truncation-artifact hypothesis from the heraldic-tag hypothesis. LongTailVerdict produces a 5-way verdict. Step 2: CipherSelfTestRunner builds a known random cipher on Linear B and Sumerian and scores SA decipherment with frequency vs epistatic anchors; targets >= 95 percent top-1 with epistatic anchors to validate the framework. Step 3: M77's measured DoFs are projected through 4 morphology CAS-YAMLs (Dravidian, Indo-Aryan, Sumerian, Elamo-Dravidian) via CPSC IterativeEngine; MultiHypothesisRanker picks the lowest max_violation. Output: reports/indus_phase15_full.json.",
  "auto_migrated": true,
  "nodes": [
    { "id": "corp_m77_full",  "type": "expNode", "data": { "atomicId": "ReferenceCorpusLoader", "label": "M77 full corpus",        "params": { "language": "indus_m77", "label": "indus_m77_full" } }, "position": { "x": 60,  "y": 60 } },
    { "id": "corp_linear_b",  "type": "expNode", "data": { "atomicId": "ReferenceCorpusLoader", "label": "Linear B corpus",        "params": { "language": "linear_b",  "label": "linear_b" } },           "position": { "x": 60,  "y": 460 } },
    { "id": "corp_sumerian",  "type": "expNode", "data": { "atomicId": "ReferenceCorpusLoader", "label": "Sumerian Ur III corpus", "params": { "language": "sumerian",  "label": "sumerian" } },           "position": { "x": 60,  "y": 540 } },

    { "id": "long_tail",      "type": "expNode", "data": { "atomicId": "LongTailFilter",      "label": "Long-tail filter (>=7)", "params": { "min_length": 7, "label": "indus_m77_long_tail" } }, "position": { "x": 320, "y": 60 } },

    { "id": "be_full",   "type": "expNode", "data": { "atomicId": "BlockEntropyProfile",       "label": "BlockEntropy full",   "params": { "max_n": 6, "label": "indus_m77_full" } },     "position": { "x": 580, "y": 30 } },
    { "id": "be_long",   "type": "expNode", "data": { "atomicId": "BlockEntropyProfile",       "label": "BlockEntropy long",   "params": { "max_n": 6, "label": "indus_m77_long" } },     "position": { "x": 580, "y": 110 } },

    { "id": "ce_long",   "type": "expNode", "data": { "atomicId": "ConditionalEntropyProfile", "label": "h(n) long-tail",      "params": {} },                                              "position": { "x": 880, "y": 110 } },

    { "id": "zipf_full", "type": "expNode", "data": { "atomicId": "ZipfMandelbrotFit",         "label": "Zipf-M full",         "params": { "label": "indus_m77_full" } },                  "position": { "x": 580, "y": 190 } },
    { "id": "zipf_long", "type": "expNode", "data": { "atomicId": "ZipfMandelbrotFit",         "label": "Zipf-M long-tail",    "params": { "label": "indus_m77_long" } },                  "position": { "x": 580, "y": 270 } },

    { "id": "mi_full",   "type": "expNode", "data": { "atomicId": "MutualInformationDecay",    "label": "MI decay full",       "params": { "max_k": 6, "label": "indus_m77_full" } },     "position": { "x": 880, "y": 30 } },
    { "id": "mi_long",   "type": "expNode", "data": { "atomicId": "MutualInformationDecay",    "label": "MI decay long-tail",  "params": { "max_k": 6, "label": "indus_m77_long" } },     "position": { "x": 880, "y": 190 } },

    { "id": "hed_full",  "type": "expNode", "data": { "atomicId": "EpistaticOrderProfile",     "label": "HED full",            "params": { "max_order": 4, "label": "indus_m77_full" } },"position": { "x": 1180, "y": 30 } },
    { "id": "hed_long",  "type": "expNode", "data": { "atomicId": "EpistaticOrderProfile",     "label": "HED long-tail",       "params": { "max_order": 4, "label": "indus_m77_long" } },"position": { "x": 1180, "y": 190 } },

    { "id": "long_verdict", "type": "expNode", "data": { "atomicId": "LongTailVerdict", "label": "Long-tail verdict (P15 step 1)", "params": {} }, "position": { "x": 1480, "y": 110 } },

    { "id": "cipher_lb", "type": "expNode", "data": { "atomicId": "CipherSelfTestRunner", "label": "Cipher self-test Linear B", "params": { "cipher_seed": 42, "n_anchors": 10, "max_iterations": 3000, "restarts": 2, "label": "linear_b" } }, "position": { "x": 320, "y": 460 } },
    { "id": "cipher_su", "type": "expNode", "data": { "atomicId": "CipherSelfTestRunner", "label": "Cipher self-test Sumerian", "params": { "cipher_seed": 42, "n_anchors": 10, "max_iterations": 3000, "restarts": 2, "label": "sumerian" } }, "position": { "x": 320, "y": 540 } },

    { "id": "dof_m77", "type": "expNode", "data": { "atomicId": "DoFExtractor", "label": "DoF extractor M77 full", "params": {} }, "position": { "x": 1480, "y": 30 } },

