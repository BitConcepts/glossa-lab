services/windows/*.local.json

# ---- Dev mode config/logs (data/ is now a project directory, not ignored globally) ----
config/
logs/

# ---- Credentials / secrets (never commit) ----
data/.keys.json
*.keys.json

# ---- Database files ----
data/glossa.db

# ---- Backend runtime logs at root ----
backend/uvicorn_stdout.log
backend/uvicorn_stderr.log
backend/rebus_test_output.txt

# ---- Keep placeholders ----
!backend/glossa_lab/data/
!backend/.gitkeep
!frontend/.gitkeep
!tray/.gitkeep
!services/windows/.gitkeep
!services/linux/.gitkeep
!services/macos/.gitkeep
!scripts/.gitkeep

# Auto-generated experiment runner stubs from run_and_watch.py (H17.6)
backend/scripts/_run_*.py

# ---- Phase-16: large acquired corpora and scratch space ----
# corpora/downloads/ holds ~3 GB of external dictionaries, OCR scans, ATF
# dumps, etc. that are not authoritative project data; the Phase-16
# extraction scripts under scripts/phase16/ regenerate the artifacts under
# backend/glossa_lab/data/phase16_corpora/ from these.
corpora/
scratch/

# Phase-16 derived corpora are large (~108 MB) and fully regenerable by
# scripts/phase16/extract_*.py. We commit only the small DoF summary files
# and the small lemma/lexicon tables; the ATF subsets, sign-sequence CSVs,
# Tamil feature matrix, and Devanagari corpus are gitignored.
backend/glossa_lab/data/phase16_corpora/cdli_*.atf
backend/glossa_lab/data/phase16_corpora/cdli_*_seqs.csv
backend/glossa_lab/data/phase16_corpora/kee2u_tamil_morpheme_features.csv
backend/glossa_lab/data/phase16_corpora/kalyanaraman_devanagari_corpus.txt


# Phase-18 derived: large stream txt regenerable from CSV
backend/glossa_lab/data/phase18_corpora/rv_padapatha_stream.txt

# ---- ML model weights (large binaries, not for version control) ----
*.pt
*.pth
*.ckpt
*.safetensors

# ---- User-uploaded PDFs (binary research docs ingested via Evidence Graph) ----
glossa-indus/raw/user_uploads/*.pdf


# governance-tool — internal agent governance state; not for public repos
.specsmith/

# governance-tool / general backup files — regeneratable, never commit
*.bak
docs/governance/*.bak
docs/*.bak

# ChronoMemory ESDB runtime files — regenerated automatically
.chronomemory/

# LaTeX build artifacts
*.aux
*.toc
*.out
*.fls
*.fdb_latexmk
*.synctex.gz

# Private correspondence — local context only, never pushed
.correspondence/
