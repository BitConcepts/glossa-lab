{
  "id": "geez_anchor_convergence_v2",
  "name": "Geez Anchor Convergence v2 (Clean Corpus, Word-Final Anchors)",
  "description": "Updated Geez anchor-convergence benchmark using Dr. Fuls' punctuation-free corpus (80,221 tokens, 209 signs). Evaluates both frequency-ranked and word-final-prioritised anchor strategies per Dr. Fuls' April 2026 suggestion: word-final signs have lower positional entropy (Ashraf & Sinha 2018) and may be better anchor candidates.",
  "nodes": [
    {
      "id": "corpus",
      "type": "expNode",
      "data": {
        "atomicId": "BuiltinCorpus",
        "label": "Geez Genesis (clean, no punct)",
        "params": { "corpus": "geez_clean" }
      },
      "position": { "x": 60, "y": 240 }
    },
    {
      "id": "split",
      "type": "expNode",
      "data": {
        "atomicId": "CorpusSplitter",
        "label": "75/25 Split",
        "params": { "train_ratio": 0.75 }
      },
      "position": { "x": 300, "y": 240 }
    },
    {
      "id": "lm",
      "type": "expNode",
      "data": {
        "atomicId": "LMBuilder",
        "label": "Syllabic LM (train)",
        "params": {}
      },
      "position": { "x": 560, "y": 100 }
    },
    {
      "id": "cipher",
      "type": "expNode",
      "data": {
        "atomicId": "CipherConstructor",
        "label": "Random Cipher",
        "params": { "cipher_seed": 42, "max_tokens": 15000 }
      },
      "position": { "x": 560, "y": 380 }
    },
    {
      "id": "benchmark",
      "type": "expNode",
      "data": {
        "atomicId": "AnchorConvergenceBenchmark",
        "label": "Anchor Sweep (freq + word-final)",
        "params": {
          "anchor_counts": [0, 3, 10, 20],
          "n_structured": 3,
          "n_random": 5,
          "n_seeds_base": 5,
          "n_seeds_struct": 3,
          "n_seeds_rand": 2,
          "sa_iterations": 2000,
          "sa_restarts": 1,
          "use_word_final_anchors": true
        }
      },
      "position": { "x": 820, "y": 240 }
    },
    {
      "id": "out",
      "type": "expNode",
      "data": {
        "atomicId": "JSONExport",
        "label": "Save Results v2",
        "params": { "filename": "geez_anchor_convergence_v2.json" }
      },
      "position": { "x": 1080, "y": 240 }
    }
  ],
  "edges": [
    { "id": "e1", "source": "corpus", "target": "split", "sourcePort": "sequences", "targetPort": "sequences" },
    { "id": "e2", "source": "split", "target": "lm", "sourcePort": "train_sequences", "targetPort": "sequences" },
    { "id": "e3", "source": "split", "target": "cipher", "sourcePort": "test_sequences", "targetPort": "sequences" },
    { "id": "e4", "source": "lm", "target": "cipher", "sourcePort": "lm", "targetPort": "lm" },
    { "id": "e5", "source": "cipher", "target": "benchmark", "sourcePort": "cipher_sequences", "targetPort": "cipher_sequences" },
    { "id": "e6", "source": "cipher", "target": "benchmark", "sourcePort": "true_mapping", "targetPort": "true_mapping" },
    { "id": "e7", "source": "cipher", "target": "benchmark", "sourcePort": "sign_inventory", "targetPort": "sign_inventory" },
    { "id": "e8", "source": "lm", "target": "benchmark", "sourcePort": "lm", "targetPort": "lm" },
    { "id": "e9", "source": "benchmark", "target": "out", "sourcePort": "summary_table", "targetPort": "data" }
  ]
}
