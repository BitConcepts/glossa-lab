indus/ocr_results/glyph_cnn.pt

# ── Corpus artifacts that SHOULD be tracked ──────────────────────────────────
# glyph_templates/   — canonical sign reference images (not regenerable without raw scans)
# staging/*.jsonl    — processed corpus objects
# canonical/         — final canonical corpus
# ocr_results/*.json — textnum indexes, validation reports, training logs
