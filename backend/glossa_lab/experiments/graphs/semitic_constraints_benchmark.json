{
  "id": "semitic_constraints_benchmark",
  "name": "Semitic Constraints Benchmark",
  "description": "Tests the effect of OCP (Obligatory Contour Principle) and positional constraints on SA decipherment quality for the NW Semitic corpus. Uses ConstraintSweep to compare consistency at 4 constraint levels: no anchors, Fuls 3-anchor, Fuls 6-anchor, Fuls 10-anchor.",
  "nodes": [
    {
      "id": "corpus",
      "type": "expNode",
      "data": {
        "atomicId": "BuiltinCorpus",
        "label": "NW Semitic",
        "params": {
          "corpus": "nw_semitic"
        }
      },
      "position": {
        "x": 60,
        "y": 200
      }
    },
    {
      "id": "rtl",
      "type": "expNode",
      "data": {
        "atomicId": "DirectionNormalizer",
        "label": "RTL",
        "params": {
          "direction": "rtl"
        }
      },
      "position": {
        "x": 280,
        "y": 200
      }
    },
    {
      "id": "lm",
      "type": "expNode",
      "data": {
        "atomicId": "BuiltinLM",
        "label": "Hebrew LM",
        "params": {
          "language": "hebrew"
        }
      },
      "position": {
        "x": 60,
        "y": 380
      }
    },
    {
      "id": "sweep",
      "type": "expNode",
      "data": {
        "atomicId": "ConstraintSweep",
        "label": "4-Level Constraint Sweep",
        "params": {
          "anchor_counts": [
            0,
            3,
            6,
            10
          ],
          "n_seeds": 5,
          "max_iterations": 5000,
          "restarts": 3
        }
      },
      "position": {
        "x": 520,
        "y": 280
      }
    },
    {
      "id": "out",
      "type": "expNode",
      "data": {
        "atomicId": "JSONExport",
        "label": "Save",
        "params": {
          "filename": "semitic_constraints_benchmark.json"
        }
      },
      "position": {
        "x": 780,
        "y": 280
      }
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source": "corpus",
      "target": "rtl",
      "sourcePort": "sequences",
      "targetPort": "sequences"
    },
    {
      "id": "e2",
      "source": "rtl",
      "target": "sweep",
      "sourcePort": "sequences",
      "targetPort": "sequences"
    },
    {
      "id": "e3",
      "source": "lm",
      "target": "sweep",
      "sourcePort": "lm",
      "targetPort": "lm"
    },
    {
      "id": "e4",
      "source": "sweep",
      "target": "out",
      "sourcePort": "consistency_curve",
      "targetPort": "data"
    }
  ],
  "graph_type": "experiment"
}