    {"id": "skt_lm",    "type": "expNode", "data": {"atomicId": "BuiltinLM",          "label": "Sanskrit LM (Rigveda 728K)",            "params": {"language": "sanskrit"}},                                                                                   "position": {"x": 60,   "y": 620}},
