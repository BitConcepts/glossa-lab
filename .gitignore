poetry.lock
Pipfile.lock

# ---- Backend local data ----
backend/.cache/
backend/.state/
backend/.runtime/
backend/logs/
backend/tmp/
backend/uploads/
backend/exports/
backend/data/
backend/models/
backend/secrets/
backend/.env
